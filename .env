# Copy to .env.local — never commit real keys.

# SQLite file (relative to project root). For Turso, use libsql URL + token instead (see README).
DATABASE_URL=file:./data/critic.db

OMDB_API_KEY=1f8f62c8

# Used to derive deterministic daily puzzles (use a long random string).
DAILY_SECRET=test_secret

# Optional: Bearer token for GET /api/cron/warm-pool (e.g. Vercel Cron sends this header).
CRON_SECRET=
